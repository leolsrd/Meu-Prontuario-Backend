// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Funcao {
  idFuncao String @id @default(uuid()) @map("id_funcao")
  funcao String
  status Boolean @default(true)
  descricao String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  // Prisma gerencia a lista de funcionários nesta função
  funcionarios Funcionario[]

  // Definindo o nome da tabela
  @@map("funcoes")
}

model Funcionario {
  idFuncionario String @id @default(uuid()) @map("id_funcionario")
  status Boolean @default(true)
  nome String
  cpfCnpj String? @unique @db.VarChar(14) @map("cpf_cnpj")
  login String
  senha String
  telefone String?
  dataNascimento DateTime? @db.Date @map("data_nascimento")
  cep String?
  logradouro String?
  complemento String?
  numero Int?
  bairro String?
  cidade String?
  uf String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  // Criando a chave estrangeira que conecta com a tabela função
  idFuncao String @map("id_funcao")
  funcao Funcao @relation(fields: [idFuncao], references: [idFuncao], onDelete: Cascade)

  medicos Medico?

  @@map("funcionarios")
}

model Medico {
  idMedico String @id @default(uuid()) @map("id_medico")
  crm String
  especialidade String
  ufCRM String @map("uf_crm")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  idFuncionario String @unique
  funcionario Funcionario @relation(fields: [idFuncionario], references: [idFuncionario], onDelete: Cascade)

  @@map("medicos")
}
